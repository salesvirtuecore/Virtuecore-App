# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_project_url

# Meta Ads API (server-side only - used in Vercel API routes)
META_ADS_APP_ID=your_meta_app_id
META_ADS_APP_SECRET=your_meta_app_secret
META_ADS_ACCESS_TOKEN=your_long_lived_access_token

# Anthropic AI (server-side only)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=notifications@virtuecore.co.uk

# Zapier webhook secret
ZAPIER_WEBHOOK_SECRET=your_zapier_webhook_secret

# Supabase service role (server-side only, for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
