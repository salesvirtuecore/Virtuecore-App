# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_project_url

# Meta Ads API (server-side only - used in Vercel API routes)
META_ADS_APP_ID=your_meta_app_id
META_ADS_APP_SECRET=your_meta_app_secret
META_ADS_ACCESS_TOKEN=your_long_lived_access_token

# Anthropic AI (server-side only)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email (Gmail SMTP)
# For Gmail you should create an App Password if 2FA is enabled, or use a secure authenticated account.
EMAIL_USER=your_gmail_username@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=VirtueCore <noreply@virtuecore.co.uk>

# n8n webhook for invite email automation
N8N_WEBHOOK_URL=https://virtualcore.app.n8n.cloud/webhook/virtuecore-invite

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_CLIENT_ID=your_stripe_connect_client_id
STRIPE_CONNECT_RETURN_URL=https://virtuecore-app.vercel.app/admin/clients
STRIPE_CONNECT_REFRESH_URL=https://virtuecore-app.vercel.app/admin/clients

# Supabase service role (server-side only, for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
